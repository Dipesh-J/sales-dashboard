# ===========================================
# Sales Dashboard — Environment Variables
# ===========================================

# --- Backend (server/) ---
# Database URL (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./sales_dashboard.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated allowed CORS origins (* for dev)
CORS_ORIGINS=*
# CORS_ORIGINS=https://your-app.vercel.app

# Redis URL (caching — app works without Redis)
REDIS_URL=redis://localhost:6379/0

# Debug mode
DEBUG=true

# --- Frontend (client/) ---
# Backend API URL
VITE_API_URL=http://localhost:8000
